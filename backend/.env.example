# Base de datos
DATABASE_URL="postgresql://usuario:contraseña@localhost:5432/drone_app"

# Servidor
PORT=3001
NODE_ENV=development

# Archivos adjuntos
UPLOADS_DIR=./uploads
MAX_FILE_SIZE_MB=10

# BCU (no requiere key, pero podemos configurar el intervalo del cron)
BCU_CRON_SCHEDULE="0 9 * * 1-5"

# Autenticación
JWT_SECRET="un-secreto-largo-y-aleatorio"
